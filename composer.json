{
    "name": "papi-ai/symfony",
    "description": "Symfony bridge for PapiAI - Integrate AI agents into your Symfony application",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Marcello Duarte",
            "email": "marcello.duarte@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "papi-ai/papi-core": "^0.8",
        "symfony/framework-bundle": "^6.4|^7.0"
    },
    "suggest": {
        "doctrine/dbal": "Required for DoctrineConversationStore",
        "symfony/messenger": "Required for MessengerQueue"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "mockery/mockery": "^1.6",
        "friendsofphp/php-cs-fixer": "^3.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "PapiAI\\Symfony\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PapiAI\\Symfony\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "XDEBUG_MODE=coverage pest --coverage --min=60",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint:fix": "php-cs-fixer fix",
        "analyse": "psalm",
        "ci": ["@lint", "@analyse", "@test:coverage"]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
